{
  "name": "power-pay",
  "version": "1.0.0",
  "description": "Power-Pay - Power computer payment gateway that handles multi-MNO integration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "migrate": "node src/database/migrations/run-migrations.js",
    "build": "npm run obfuscate",
    "obfuscate": "javascript-obfuscator src --output dist --compact true --control-flow-flattening true --dead-code-injection true --string-array true --disable-console-output false --target node",
    "build:prod": "npm run build && xcopy package.json dist\\ /Y && xcopy .env.example dist\\ /Y",
    "start:prod": "node dist/server.js"
  },
  "keywords": [
    "payment",
    "gateway",
    "stanbic",
    "selcom",
    "mno"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "moment": "^2.29.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "javascript-obfuscator": "^4.1.0",
    "rimraf": "^3.0.2"
  }
}

{
  "info": {
    "name": "Power-Pay Gateway API v2.2",
    "description": "Complete API collection with Stanbic dedicated endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "power-pay-v2.2"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "reference",
      "value": "ABC123456",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "pk_test_1234567890abcdef1234567890abcdef12345678",
      "type": "string"
    },
    {
      "key": "stanbic_secret",
      "value": "test_secret_stanbic_2024",
      "type": "string"
    },
    {
      "key": "institution_id",
      "value": "BILLER001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Root Endpoint - List All APIs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "🏦 Stanbic Bank Endpoints",
      "description": "Dedicated endpoints for Stanbic Bank integration with token + checksum authentication",
      "item": [
        {
          "name": "Stanbic Lookup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('Lookup successful:', jsonData.data);",
                  "    pm.collectionVariables.set('reference', jsonData.data.reference);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{reference}}\",\n  \"institutionId\": \"{{institution_id}}\",\n  \"checksum\": \"9f86d081884c7d659a2feaa0c55ad015\",\n  \"token\": \"{{stanbic_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/stanbic/lookup",
              "host": ["{{base_url}}"],
              "path": ["api", "stanbic", "lookup"]
            },
            "description": "Verify payment reference exists in Power-Pay. Returns amount, payer details, payment description, etc."
          }
        },
        {
          "name": "Stanbic Callback",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('Callback processed:', jsonData.data);",
                  "    console.log('Receipt:', jsonData.data.receipt);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{reference}}\",\n  \"amount\": 25000.00,\n  \"institutionId\": \"{{institution_id}}\",\n  \"payerName\": \"John Doe\",\n  \"payType\": \"001\",\n  \"amountType\": \"FULL\",\n  \"currency\": \"TZS\",\n  \"paymentDesc\": \"Utility Bill Payment\",\n  \"payerPhone\": \"+255712345678\",\n  \"channel\": \"MOBILE_APP\",\n  \"transactionDate\": \"2025-08-19T13:45:30\",\n  \"transactionId\": \"TXN789654123\",\n  \"checksum\": \"9f86d081884c7d659a2feaa0c55ad015\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/stanbic/callback",
              "host": ["{{base_url}}"],
              "path": ["api", "stanbic", "callback"]
            },
            "description": "Send payment confirmation after customer pays. Returns receipt UUID and timestamp."
          }
        },
        {
          "name": "📝 Checksum Generator Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Generate checksum using:\n\nNode.js:\nconst crypto = require('crypto');\nconst data = { reference: 'ABC123456', institutionId: 'BILLER001' };\nconst checksum = crypto.createHmac('sha256', secret).update(JSON.stringify(data)).digest('hex');\n\nPHP:\n$data = ['reference' => 'ABC123456', 'institutionId' => 'BILLER001'];\n$checksum = hash_hmac('sha256', json_encode($data), $secret);"
          }
        }
      ]
    },
    {
      "name": "🧪 Stanbic Complete Test Flow",
      "description": "4-step test workflow for Stanbic integration",
      "item": [
        {
          "name": "1. Create Payment (Bypass MNO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment created with bypass', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal('PENDING');",
                  "    pm.collectionVariables.set('transaction_id', jsonData.transaction_id);",
                  "    pm.collectionVariables.set('reference', jsonData.reference);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"STANBIC-FLOW-001\",\n  \"amount\": 25000,\n  \"mno_provider\": \"STANBIC\",\n  \"client_system\": \"HOSPITAL_SYSTEM\",\n  \"payer_name\": \"John Doe\",\n  \"payer_phone\": \"+255712345678\",\n  \"payment_desc\": \"Utility Bill Payment\",\n  \"bypass_mno\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/process",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "process"]
            },
            "description": "Hospital/Client creates payment. Power-Pay saves it WITHOUT calling Stanbic."
          }
        },
        {
          "name": "2. Stanbic Lookup (Verify)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payment found in lookup', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.amount).to.equal(25000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"STANBIC-FLOW-001\",\n  \"institutionId\": \"{{institution_id}}\",\n  \"checksum\": \"9f86d081884c7d659a2feaa0c55ad015\",\n  \"token\": \"{{stanbic_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/stanbic/lookup",
              "host": ["{{base_url}}"],
              "path": ["api", "stanbic", "lookup"]
            },
            "description": "Customer goes to Stanbic. Stanbic verifies payment exists in Power-Pay."
          }
        },
        {
          "name": "3. Stanbic Callback (Confirm Payment)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Callback processed', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.receipt).to.exist;",
                  "    console.log('Receipt:', jsonData.data.receipt);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"STANBIC-FLOW-001\",\n  \"amount\": 25000.00,\n  \"institutionId\": \"{{institution_id}}\",\n  \"payerName\": \"John Doe\",\n  \"payType\": \"001\",\n  \"amountType\": \"FULL\",\n  \"currency\": \"TZS\",\n  \"paymentDesc\": \"Utility Bill Payment\",\n  \"payerPhone\": \"+255712345678\",\n  \"channel\": \"MOBILE_APP\",\n  \"transactionDate\": \"2025-08-19T13:45:30Z\",\n  \"transactionId\": \"TXN789654123\",\n  \"checksum\": \"9f86d081884c7d659a2feaa0c55ad015\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/stanbic/callback",
              "host": ["{{base_url}}"],
              "path": ["api", "stanbic", "callback"]
            },
            "description": "After processing payment, Stanbic sends confirmation to Power-Pay."
          }
        },
        {
          "name": "4. Verify Status Updated",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is SUCCESS', function() {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.status).to.equal('SUCCESS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/lookup?reference=STANBIC-FLOW-001",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "lookup"],
              "query": [{"key": "reference", "value": "STANBIC-FLOW-001"}]
            },
            "description": "Verify transaction is now SUCCESS with receipt number."
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('auth_token', jsonData.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Payments - Standard Flow",
      "item": [
        {
          "name": "Verify Payment - Stanbic",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{reference}}\",\n  \"mno_provider\": \"STANBIC\",\n  \"client_system\": \"HOSPITAL_SYSTEM\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "verify"]
            }
          }
        },
        {
          "name": "Process Payment - Normal (Sends to MNO)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{reference}}\",\n  \"amount\": 50000,\n  \"mno_provider\": \"STANBIC\",\n  \"client_system\": \"HOSPITAL_SYSTEM\",\n  \"payer_name\": \"John Doe Mwamba\",\n  \"payer_phone\": \"+255712345678\",\n  \"payment_desc\": \"Hospital Bill Payment\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/process",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "process"]
            }
          }
        }
      ]
    },
    {
      "name": "🆕 MNO Features - Bypass & Callback",
      "item": [
        {
          "name": "Process Payment - BYPASS MNO",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"BYPASS123\",\n  \"amount\": 75000,\n  \"mno_provider\": \"STANBIC\",\n  \"client_system\": \"HOSPITAL_SYSTEM\",\n  \"payer_name\": \"Mary Kamwendo\",\n  \"payer_phone\": \"+255787654321\",\n  \"payment_desc\": \"Hospital Emergency Bill\",\n  \"bypass_mno\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/process",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "process"]
            }
          }
        },
        {
          "name": "Lookup Transaction by Reference",
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/lookup?reference={{reference}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "lookup"],
              "query": [{"key": "reference", "value": "{{reference}}"}]
            }
          }
        },
        {
          "name": "Payment Callback",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{reference}}\",\n  \"receipt_number\": \"RCP-2024-001234\",\n  \"status\": \"SUCCESS\",\n  \"payment_date\": \"2024-01-20T11:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payments/callback",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "callback"]
            }
          }
        }
      ]
    },
    {
      "name": "Transaction Queries",
      "item": [
        {
          "name": "Get Transaction Status",
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/status/{{transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "status", "{{transaction_id}}"]
            }
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "header": [
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/payments/history/HOSPITAL_SYSTEM?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "payments", "history", "HOSPITAL_SYSTEM"],
              "query": [{"key": "limit", "value": "50"}]
            }
          }
        }
      ]
    },
    {
      "name": "Selcom Payments",
      "item": [
        {
          "name": "Process - Selcom GEPG",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-API-Key", "value": "{{api_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"991234567891\",\n  \"amount\": 15000,\n  \"mno_provider\": \"SELCOM\",\n  \"client_system\": \"UTILITY\",\n  \"payer_name\": \"Ahmed Hassan\",\n  \"payer_phone\": \"+255765432109\",\n  \"utility_code\": \"GEPG\"\n}"
